<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  
  <ThingDef>
    <defName>Filth_Dye</defName>
    <thingClass>MiningOutpost.FilthRandomDye</thingClass>
    <label>dye spawner</label>
    <description>Layout helper that spawns random colored dye.</description>
    <category>Filth</category>
    <selectable>false</selectable>
    <useHitPoints>false</useHitPoints>
    <altitudeLayer>Filth</altitudeLayer>
    <graphicData>
      <texPath>Things/Filth/Grainy</texPath>
      <graphicClass>Graphic_Cluster</graphicClass>
      <color>(180,40,40,90)</color>
    </graphicData>
  </ThingDef>

  

  <ThingDef ParentName="BaseFilth">
    <defName>Filth_DyeRed</defName>
    <label>red dye</label>
    <description>A splotch of spilled red dye.</description>
    <graphicData>
      <texPath>Things/Filth/Grainy</texPath>
      <color>(185,35,35,90)</color>
    </graphicData>
    <filth>
      <placementMask><li>Terrain</li></placementMask>
      <disappearsInDays>45~50</disappearsInDays>
      <cleaningWorkToReduceThickness>35</cleaningWorkToReduceThickness>
      <canFilthAttach>true</canFilthAttach>
      <cleaningSound>Interact_CleanFilth_Dirt</cleaningSound>
    </filth>
    <statBases>
      <Beauty>-3</Beauty>
      <Cleanliness>-2</Cleanliness>
    </statBases>
  </ThingDef>

