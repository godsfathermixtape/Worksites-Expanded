<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <QuestScriptDef ParentName="Base_WorkSiteExpanded" MayRequire="OskarPotocki.VanillaVehiclesExpandedTier3">
    <defName>OpportunitySite_VehiclesTier3Outpost</defName>
    <rootSelectionWeight>0.25</rootSelectionWeight>

    <questNameRules>
      <rulesStrings>
        <li>questName(isFirstQuest==false)->The [adjective] [vehType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [vehType]</li>
        <li>questName(isFirstQuest==false)->[vehType] [detected]</li>
        <li>questName(isFirstQuest==false)->[enemyFaction_name]'s [vehType]</li>
        <li>questName(isFirstQuest==false)->The [vehType] of [enemyFaction_name]</li>
        <li>adjective->Exclusive</li>
        <li>adjective->Fortified</li>
        <li>adjective->Guarded</li>
        <li>adjective->High-Value</li>
        <li>adjective->Prized</li>
        <li>adjective->Secured</li>
        <li>adjective->Well-Defended</li>
        <li>vehType->Compound</li>
        <li>vehType->Depot</li>
        <li>vehType->Hangar</li>
        <li>vehType->Holding Bay</li>
        <li>vehType->Secure Garage</li>
        <li>vehType->Storage Compound</li>
        <li>vehType->Vehicle Cache</li>
        <li>vehType->Vehicle Vault</li>
        <li>detected->detected</li>
        <li>detected->discovered</li>
        <li>detected->identified</li>
        <li>detected->located</li>
        <li>detected->traced</li>
        <li>detected->uncovered</li>
      </rulesStrings>
    </questNameRules>

    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription(isFirstQuest==false)->[discoveryMethod] a [siteType] near [map_definite]. [intelReport][factionDescriptor]\n\n[factionWarning]\n\n[rewardHint]</li>

        <li>siteType->guarded vehicle compound</li>
        <li>siteType->secured depot</li>
        <li>siteType->high-value vehicle cache</li>
        <li>siteType->fortified holding bay</li>
        <li>siteType->private vehicle vault</li>
	<li>intelReport->[enemyFaction_name] is working on something significant out of this site. Whatever vehicle they have inside is rumored to be far from ordinary.</li>
        <li>intelReport->The smell of oil and the sound of V12 engines suggests [enemyFaction_name] have something valuable parked inside. Jet fuel barrels litter the yard.</li>
        <li>intelReport->[enemyFaction_name] has been using this place to store and maintain a vehicle that isn't easy to replace.</li>
        <li>intelReport->Tread marks in the mud point to [enemyFaction_name]'s garage. A vehicle is parked inside, along with parts.</li>
        <li>intelReport->Specialist mechanics from [enemyFaction_name] have been seen coming and going from this site. They have been maintaining something with an engine.</li>
        <li>intelReport->Intelligence suggests [enemyFaction_name] run a vehicle garage at this location. Specialist parts and fuel arrive under escort.</li>

        <li>rewardHint->Defeating the mercenaries at the site would yield parts, fuel, and the vehicle itself.</li>
        <li>rewardHint->A successful raid would likely yield a functional vehicle along with the spare parts and chemfuel needed to keep it going.</li>
        <li>rewardHint->Their warehouses likely contain tools and a useful stockpile of vehicle components.</li>
        <li>rewardHint->The loot at this site will likely be on wheels. Its parts alone would be valuable commodities.</li>
      </rulesStrings>
    </questDescriptionRules>

    <root Class="QuestNode_Sequence">
      <nodes>
        <li Class="QuestNode_SubScript">
          <def>Util_GetDefaultRewardValueFromPoints</def>
        </li>
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="MiningOutpost.QuestNode_GetMapFallback" />

        <li Class="MiningOutpost.QuestNode_GetMiningFaction">
          <storeAs>enemyFaction</storeAs>
          <storeTemporaryAs>faction_temporary</storeTemporaryAs>
          <storeCorporateDescAs>factionDescriptor</storeCorporateDescAs>
          <storeColoredNameAs>coloredFactionName</storeColoredNameAs>
          <siteType>Vehicles</siteType>
        </li>

        <li Class="MiningOutpost.QuestNode_UniversalSafeTileFinder">
          <storeAs>siteTile</storeAs>
          <minDistance>3</minDistance>
          <maxDistance>28</maxDistance>
        </li>

        <li Class="QuestNode_AddToList">
          <name>sitePartDefs</name>
          <value>VehiclesTier3Outpost</value>
        </li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>

        <li Class="QuestNode_GenerateSite">
          <sitePartsParams>$sitePartsParams</sitePartsParams>
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <storeAs>site</storeAs>
        </li>

        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,30)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <destroyOnCleanup>true</destroyOnCleanup>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest expired: [resolvedQuestName]</label>
                <text>[enemyFaction_name] has relocated their combat vehicles. The quest [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest failed: [resolvedQuestName]</label>
                <text>[enemyFaction_name] has evacuated their vehicles after being discovered. The quest [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Notify_PlayerRaidedSomeone">
                <getRaidersFromMapParent>$site</getRaidersFromMapParent>
              </li>
              <li Class="QuestNode_CampLootReward" />
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_End">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <outcome>Success</outcome>
        </li>

        <li Class="QuestNode_NoWorldObject">
          <worldObject>$site</worldObject>
          <node Class="QuestNode_End">
            <outcome>Fail</outcome>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
</Defs>
