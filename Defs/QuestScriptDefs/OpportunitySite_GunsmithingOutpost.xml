<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <QuestScriptDef ParentName="Base_WorkSiteExpanded">
    <defName>OpportunitySite_GunsmithingOutpost</defName>

    <questNameRules>
      <rulesStrings>
        <li>questName(isFirstQuest==false)->The [adjective] [gunType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [gunType]</li>
        <li>questName(isFirstQuest==false)->[gunType] [detected]</li>
        <li>questName(isFirstQuest==false)->[enemyFaction_name]'s [gunType]</li>
        <li>questName(isFirstQuest==false)->[adjective] Arms [camp]</li>
        <li>questName(isFirstQuest==false)->The [gunType] of [enemyFaction_name]</li>
        <li>adjective->Fortified</li>
        <li>adjective->Hidden</li>
        <li>adjective->Defended</li>
        <li>adjective->Remote</li>
        <li>adjective->Industrial</li>
        <li>adjective->Smoky</li>
        <li>adjective->Armed</li>
        <li>gunType->Gunsmith</li>
        <li>gunType->Armory</li>
        <li>gunType->Weapons Factory</li>
        <li>gunType->Arms Depot</li>
        <li>gunType->Forge</li>
        <li>gunType->Arsenal</li>
        <li>camp->Depot</li>
        <li>camp->Cache</li>
        <li>camp->Stockpile</li>
        <li>detected->detected</li>
        <li>detected->discovered</li>
        <li>detected->spotted</li>
        <li>detected->located</li>
        <li>detected->identified</li>
      </rulesStrings>
    </questNameRules>

    <questDescriptionRules>
      <rulesStrings>
        
        <li>questDescription(isFirstQuest==false)->[discoveryMethod] a [siteType] near [map_definite]. [intelReport][factionDescriptor]\n\n[factionWarning]\n\n[rewardHint]</li>

        
        <li>siteType->gunsmithing workshop</li>
        <li>siteType->weapons factory</li>
        <li>siteType->arms depot</li>
        <li>siteType->forge</li>
        <li>siteType->armory</li>

        
        <li>intelReport->The workshop is operated by [enemyFaction_name], they are actively manufacturing firearms and ammunition.</li>
        <li>intelReport->[enemyFaction_name] has established this site for weapons production. Weaponry is bought and sold here.</li>
        <li>intelReport->Intelligence suggests [enemyFaction_name] manufactures weapons here. Crates of arms and gun parts fill the storage yards.</li>
        <li>intelReport->The facility belongs to [enemyFaction_name]. Smoke and the sound of weapons testing suggest weapons are manufactured here.</li>
        <li>intelReport->Surveillance confirms [enemyFaction_name] run an arms operation here. Shipments of finished weapons leave regularly.</li>

        
        <li>rewardHint->Defeating them would yield weapons, ammunition, and gun parts.</li>
        <li>rewardHint->A successful assault could provide quality firearms and tools.</li>
        <li>rewardHint->Their armory likely contains finished weapons and stockpiled ammunition.</li>
        <li>rewardHint->Eliminating the gunsmiths would let you claim their weapons stockpile and equipment.</li>
      </rulesStrings>
    </questDescriptionRules>

    <root Class="QuestNode_Sequence">
      <nodes>
        
        <li Class="QuestNode_SubScript">
          <def>Util_GetDefaultRewardValueFromPoints</def>
        </li>
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="MiningOutpost.QuestNode_GetMapFallback" />

        
        <li Class="MiningOutpost.QuestNode_GetMiningFaction">
          <storeAs>enemyFaction</storeAs>
          <storeTemporaryAs>faction_temporary</storeTemporaryAs>
          <storeCorporateDescAs>factionDescriptor</storeCorporateDescAs>
          <storeColoredNameAs>coloredFactionName</storeColoredNameAs>
          <siteType>Gunsmithing</siteType>
        </li>

        
        <li Class="MiningOutpost.QuestNode_UniversalSafeTileFinder">
          <storeAs>siteTile</storeAs>
          <minDistance>3</minDistance>
          <maxDistance>28</maxDistance>
        </li>

        <li Class="QuestNode_AddToList">
          <name>sitePartDefs</name>
          <value>GunsmithingOutpost</value>
        </li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>

        <li Class="QuestNode_GenerateSite">
          <sitePartsParams>$sitePartsParams</sitePartsParams>
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <storeAs>site</storeAs>
        </li>

        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        
        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,30)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <destroyOnCleanup>true</destroyOnCleanup>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest expired: [resolvedQuestName]</label>
                <text>The gunsmithing workshop operated by [enemyFaction_name] has been dismantled and moved. The quest [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest failed: [resolvedQuestName]</label>
                <text>After being discovered, [enemyFaction_name] has destroyed their weapon forges and fled. The quest [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Notify_PlayerRaidedSomeone">
                <getRaidersFromMapParent>$site</getRaidersFromMapParent>
              </li>
              <li Class="QuestNode_CampLootReward" />
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_End">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <outcome>Success</outcome>
        </li>

        <li Class="QuestNode_NoWorldObject">
          <worldObject>$site</worldObject>
          <node Class="QuestNode_End">
            <outcome>Fail</outcome>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
</Defs>
