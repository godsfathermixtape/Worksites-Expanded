<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <QuestScriptDef ParentName="Base_WorkSiteExpanded">
    <defName>OpportunitySite_ComponentOutpost</defName>

    <questNameRules>
      <rulesStrings>
        <li>questName(isFirstQuest==false)->The [adjective] [compType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [compType]</li>
        <li>questName(isFirstQuest==false)->[compType] [detected]</li>
        <li>questName(isFirstQuest==false)->[enemyFaction_name]'s [compType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [partType] Plant</li>
        <li>questName(isFirstQuest==false)->The [compType] of [enemyFaction_name]</li>
        <li>adjective->Industrial</li>
        <li>adjective->Precision</li>
        <li>adjective->Advanced</li>
        <li>adjective->Hidden</li>
        <li>adjective->Remote</li>
        <li>adjective->Defended</li>
        <li>adjective->Automated</li>
        <li>compType->Component Factory</li>
        <li>compType->Assembly Plant</li>
        <li>compType->Electronics Facility</li>
        <li>compType->Tech Workshop</li>
        <li>compType->Manufacturing Plant</li>
        <li>compType->Circuit Foundry</li>
        <li>partType->Component</li>
        <li>partType->Circuit</li>
        <li>partType->Electronics</li>
        <li>detected->detected</li>
        <li>detected->discovered</li>
        <li>detected->spotted</li>
        <li>detected->located</li>
        <li>detected->identified</li>
      </rulesStrings>
    </questNameRules>

    <questDescriptionRules>
      <rulesStrings>
        
        <li>questDescription(isFirstQuest==false)->[discoveryMethod] a [siteType] near [map_definite]. [intelReport][factionDescriptor]\n\n[factionWarning]\n\n[rewardHint]</li>

        
        <li>siteType->component factory</li>
        <li>siteType->assembly plant</li>
        <li>siteType->electronics workshop</li>
        <li>siteType->manufacturing facility</li>
        <li>siteType->tech foundry</li>

        
        <li>intelReport->The factory is operated by [enemyFaction_name] and produces components and electronic assemblies.</li>
        <li>intelReport->[enemyFaction_name] has established this as a precision manufacturing site. Electronics are bought and sold here.</li>
        <li>intelReport->Intelligence suggests [enemyFaction_name] fabricates electronics here. Crates of finished components and circuit boards are stacked in the warehouse.</li>
        <li>intelReport->The facility belongs to [enemyFaction_name]. Automated machinery and the glow of furnaces indicate a busy factory.</li>
        <li>intelReport->Surveillance confirms [enemyFaction_name] manufactures electronics at this location. Supply convoys regularly depart loaded with finished circuits.</li>

        
        <li>rewardHint->Defeating them would yield components, electronics, and manufactured goods.</li>
        <li>rewardHint->A successful raid could provide valuable electronics.</li>
        <li>rewardHint->Their warehouse likely contains finished components and advanced electronics.</li>
        <li>rewardHint->Eliminating the workers would let you claim their component stockpile and assembly equipment.</li>
      </rulesStrings>
    </questDescriptionRules>

    <root Class="QuestNode_Sequence">
      <nodes>
        
        <li Class="QuestNode_SubScript">
          <def>Util_GetDefaultRewardValueFromPoints</def>
        </li>
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="MiningOutpost.QuestNode_GetMapFallback" />

        
        <li Class="MiningOutpost.QuestNode_GetMiningFaction">
          <storeAs>enemyFaction</storeAs>
          <storeTemporaryAs>faction_temporary</storeTemporaryAs>
          <storeCorporateDescAs>factionDescriptor</storeCorporateDescAs>
          <storeColoredNameAs>coloredFactionName</storeColoredNameAs>
          <siteType>ComponentManufacture</siteType>
        </li>

        
        <li Class="MiningOutpost.QuestNode_UniversalSafeTileFinder">
          <storeAs>siteTile</storeAs>
          <minDistance>3</minDistance>
          <maxDistance>28</maxDistance>
        </li>

        <li Class="QuestNode_AddToList">
          <name>sitePartDefs</name>
          <value>ComponentOutpost</value>
        </li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>

        <li Class="QuestNode_GenerateSite">
          <sitePartsParams>$sitePartsParams</sitePartsParams>
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <storeAs>site</storeAs>
        </li>

        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        
        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,30)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <destroyOnCleanup>true</destroyOnCleanup>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest expired: [resolvedQuestName]</label>
                <text>The component factory operated by [enemyFaction_name] has shut down and relocated. The quest [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest failed: [resolvedQuestName]</label>
                <text>After being discovered, [enemyFaction_name] has dismantled their assembly lines and escaped. The quest [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Notify_PlayerRaidedSomeone">
                <getRaidersFromMapParent>$site</getRaidersFromMapParent>
              </li>
              <li Class="QuestNode_CampLootReward" />
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_End">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <outcome>Success</outcome>
        </li>

        <li Class="QuestNode_NoWorldObject">
          <worldObject>$site</worldObject>
          <node Class="QuestNode_End">
            <outcome>Fail</outcome>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
</Defs>
