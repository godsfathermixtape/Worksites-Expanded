<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <QuestScriptDef ParentName="Base_WorkSiteExpanded">
    <defName>OpportunitySite_MiningOutpost</defName>
    
    <questNameRules>
      <rulesStrings>
        <li>questName(isFirstQuest==false)->The [adjective] Mining [camp]</li>
        <li>questName(isFirstQuest==false)->[adjective] Mining [camp]</li>
        <li>questName(isFirstQuest==false)->Mining [camp] [detected]</li>
        <li>questName(isFirstQuest==false)->[enemyFaction_name]'s Mining [camp]</li>
        <li>questName(isFirstQuest==false)->[adjective] [oreType] Mine</li>
        <li>adjective->Remote</li>
        <li>adjective->Hidden</li>
        <li>adjective->Fortified</li>
        <li>adjective->Distant</li>
        <li>adjective->Defended</li>
        <li>adjective->Deep</li>
        <li>adjective->Rich</li>
        <li>camp->Outpost</li>
        <li>camp->Camp</li>
        <li>camp->Site</li>
        <li>camp->Facility</li>
        <li>camp->Operation</li>
        <li>camp->Quarry</li>
        <li>oreType->Steel</li>
        <li>oreType->Gold</li>
        <li>oreType->Plasteel</li>
        <li>oreType->Component</li>
        <li>detected->detected</li>
        <li>detected->discovered</li>
        <li>detected->nearby</li>
        <li>detected->located</li>
        <li>detected->found</li>
      </rulesStrings>
    </questNameRules>
    
    <questDescriptionRules>
      <rulesStrings>
        
        <li>questDescription(isFirstQuest==false)->[discoveryMethod] a mining [siteType] near [map_definite]. [intelReport][factionDescriptor]\n\n[factionWarning]\n\n[rewardHint]</li>
        
        
        <li>siteType->outpost</li>
        <li>siteType->facility</li>
        <li>siteType->camp</li>
        <li>siteType->operation</li>
        <li>siteType->dig site</li>
        <li>siteType->quarry</li>
        
        
        <li>intelReport->Rumors suggests the facility is operated by [enemyFaction_name] and contains valuable ore and equipment.</li>
        <li>intelReport->The site appears to be a subsidiary operation of [enemyFaction_name], extracting valuable minerals from the region.</li>
        <li>intelReport->Research indicates [enemyFaction_name] has established this mining operation recently. It's likely stocked with resources.</li>
        <li>intelReport->The operation belongs to [enemyFaction_name]. It's expected they store raw metals here.</li>
        <li>intelReport->Seismic activity was detected at this site. [enemyFaction_name] appears to be extracting valuable ores.</li>
        
        
        <li>rewardHint->If you assault it and destroy their defenses, you can claim whatever resources remain.</li>
        <li>rewardHint->Eliminating the defenders would allow you to salvage their mining equipment and stockpiled ore.</li>
        <li>rewardHint->A successful raid could yield valuable minerals and industrial equipment.</li>
        <li>rewardHint->Their ore stockpiles and mining gear would make excellent salvage.</li>
      </rulesStrings>
    </questDescriptionRules>
    
    <root Class="QuestNode_Sequence">
      <nodes>
        
        <li Class="QuestNode_SubScript">
          <def>Util_GetDefaultRewardValueFromPoints</def>
        </li>
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="MiningOutpost.QuestNode_GetMapFallback" />

        
        <li Class="MiningOutpost.QuestNode_GetMiningFaction">
          <storeAs>enemyFaction</storeAs>
          <storeTemporaryAs>faction_temporary</storeTemporaryAs>
          <storeCorporateDescAs>factionDescriptor</storeCorporateDescAs>
          <storeColoredNameAs>coloredFactionName</storeColoredNameAs>
          <siteType>Mining</siteType>
        </li>

		
		<li Class="MiningOutpost.QuestNode_UniversalSafeTileFinder">
		  <storeAs>siteTile</storeAs>
		  <minDistance>3</minDistance>
		  <maxDistance>28</maxDistance>
		</li>

        <li Class="QuestNode_AddToList">
          <name>sitePartDefs</name>
          <value>MiningOutpost</value>
        </li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>

        <li Class="QuestNode_GenerateSite">
          <sitePartsParams>$sitePartsParams</sitePartsParams>
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <storeAs>site</storeAs>
        </li>

        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        
        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,30)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <destroyOnCleanup>true</destroyOnCleanup>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest expired: [resolvedQuestName]</label>
                <text>The mining outpost operated by [enemyFaction_name] has packed up and relocated. The quest [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest failed: [resolvedQuestName]</label>
                <text>After being discovered, the mining outpost operated by [enemyFaction_name] has dispersed and abandoned the site. The quest [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Notify_PlayerRaidedSomeone">
                <getRaidersFromMapParent>$site</getRaidersFromMapParent>
              </li>
              <li Class="QuestNode_CampLootReward" />
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_End">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <outcome>Success</outcome>
        </li>

        <li Class="QuestNode_NoWorldObject">
          <worldObject>$site</worldObject>
          <node Class="QuestNode_End">
            <outcome>Fail</outcome>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
</Defs>