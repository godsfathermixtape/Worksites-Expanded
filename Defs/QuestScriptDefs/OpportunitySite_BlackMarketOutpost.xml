<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <QuestScriptDef ParentName="Base_WorkSiteExpanded">
    <defName>OpportunitySite_BlackMarketOutpost</defName>

    <questNameRules>
      <rulesStrings>
        <li>questName(isFirstQuest==false)->The [adjective] [bmType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [bmType]</li>
        <li>questName(isFirstQuest==false)->[bmType] [detected]</li>
        <li>questName(isFirstQuest==false)->[enemyFaction_name]'s [bmType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [contrabandType] Ring</li>
        <li>questName(isFirstQuest==false)->The [bmType] of [enemyFaction_name]</li>
        <li>adjective->Hidden</li>
        <li>adjective->Secret</li>
        <li>adjective->Underground</li>
        <li>adjective->Shadow</li>
        <li>adjective->Dark</li>
        <li>adjective->Notorious</li>
        <li>adjective->Shady</li>
        <li>bmType->Black Market</li>
        <li>bmType->Smuggler's Den</li>
        <li>bmType->Underground Exchange</li>
        <li>bmType->Contraband Hub</li>
        <li>bmType->Shadow Market</li>
        <li>bmType->Crime Ring</li>
        <li>contrabandType->Smuggling</li>
        <li>contrabandType->Drug</li>
        <li>contrabandType->Contraband</li>
        <li>detected->detected</li>
        <li>detected->discovered</li>
        <li>detected->exposed</li>
        <li>detected->located</li>
        <li>detected->uncovered</li>
      </rulesStrings>
    </questNameRules>

    <questDescriptionRules>
      <rulesStrings>
        
        <li>questDescription(isFirstQuest==false)->[discoveryMethod] a [siteType] near [map_definite]. [intelReport][factionDescriptor]\n\n[factionWarning]\n\n[rewardHint]</li>

        
        <li>siteType->black market den</li>
        <li>siteType->smuggler's hideout</li>
        <li>siteType->underground marketplace</li>
        <li>siteType->contraband exchange</li>
        <li>siteType->shadow market</li>

        
        <li>intelReport->The den is operated by [enemyFaction_name] and deals in illegal goods, drugs, and stolen merchandise.</li>
        <li>intelReport->[enemyFaction_name] has established this as a smuggling hub. Illicit goods are bought and sold here.</li>
        <li>intelReport->Rumors suggest [enemyFaction_name] illegally trades here. Drug labs and weapon caches are hidden.</li>
        <li>intelReport->The hideout belongs to [enemyFaction_name]. Armed thugs and concealed entrances indicate a well-organized criminal enterprise.</li>
        <li>intelReport->Rumors suggest [enemyFaction_name] operates a black market at this location. Heavily guarded contraband shipments regularly arrive here.</li>

        
        <li>rewardHint->Defeating them would yield drugs, contraband, weapons, and ill-gotten gains.</li>
        <li>rewardHint->A successful raid could provide black market goods and hidden silver.</li>
        <li>rewardHint->Their stash houses likely contain drugs, weapons, and stolen valuables.</li>
        <li>rewardHint->Eliminating the smugglers would allow you to claim their contraband and hidden wealth.</li>
      </rulesStrings>
    </questDescriptionRules>

    <root Class="QuestNode_Sequence">
      <nodes>
        
        <li Class="QuestNode_SubScript">
          <def>Util_GetDefaultRewardValueFromPoints</def>
        </li>
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="MiningOutpost.QuestNode_GetMapFallback" />

        
        <li Class="MiningOutpost.QuestNode_GetMiningFaction">
          <storeAs>enemyFaction</storeAs>
          <storeTemporaryAs>faction_temporary</storeTemporaryAs>
          <storeCorporateDescAs>factionDescriptor</storeCorporateDescAs>
          <storeColoredNameAs>coloredFactionName</storeColoredNameAs>
          <siteType>BlackMarket</siteType>
        </li>

        
        <li Class="MiningOutpost.QuestNode_UniversalSafeTileFinder">
          <storeAs>siteTile</storeAs>
          <minDistance>3</minDistance>
          <maxDistance>28</maxDistance>
        </li>

        <li Class="QuestNode_AddToList">
          <name>sitePartDefs</name>
          <value>BlackMarketOutpost</value>
        </li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>

        <li Class="QuestNode_GenerateSite">
          <sitePartsParams>$sitePartsParams</sitePartsParams>
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <storeAs>site</storeAs>
        </li>

        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        
        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,30)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <destroyOnCleanup>true</destroyOnCleanup>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest expired: [resolvedQuestName]</label>
                <text>The black market operated by [enemyFaction_name] has scattered and relocated to a new hideout. The quest [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest failed: [resolvedQuestName]</label>
                <text>After being discovered, the smugglers from [enemyFaction_name] have burned their contraband and vanished. The quest [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        
        <li Class="QuestNode_Signal">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Notify_PlayerRaidedSomeone">
                <getRaidersFromMapParent>$site</getRaidersFromMapParent>
              </li>
              <li Class="QuestNode_CampLootReward" />
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_End">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <outcome>Success</outcome>
        </li>

        <li Class="QuestNode_NoWorldObject">
          <worldObject>$site</worldObject>
          <node Class="QuestNode_End">
            <outcome>Fail</outcome>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>
</Defs>
