<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <QuestScriptDef ParentName="Base_WorkSiteExpanded">
    <defName>OpportunitySite_HomesteadOutpost</defName>

    <rootSelectionWeight>1.5</rootSelectionWeight>
    <defaultChallengeRating>1</defaultChallengeRating>

    <questNameRules>
      <rulesStrings>
        <li>questName(isFirstQuest==false)->The [adjective] [homeType]</li>
        <li>questName(isFirstQuest==false)->[adjective] [homeType]</li>
        <li>questName(isFirstQuest==false)->[homeType] [detected]</li>
        <li>questName(isFirstQuest==false)->[enemyFaction_name]'s [homeType]</li>
        <li>adjective->Abandoned</li>
        <li>adjective->Remote</li>
        <li>adjective->Isolated</li>
        <li>adjective->Fringe</li>
        <li>adjective->Hidden</li>
        <li>adjective->Frontier</li>
        <li>adjective->Wilderness</li>
        <li>homeType->Homestead</li>
        <li>homeType->Cabin</li>
        <li>homeType->Hovel</li>
        <li>homeType->Dwelling</li>
        <li>homeType->Settlement</li>
        <li>homeType->Outpost</li>
        <li>detected->detected</li>
        <li>detected->discovered</li>
        <li>detected->nearby</li>
        <li>detected->located</li>
        <li>detected->found</li>
      </rulesStrings>
    </questNameRules>

    <questDescriptionRules>
      <rulesStrings>

        <li>questDescription(isFirstQuest==false)->[discoveryMethod] a [siteType] near [map_definite]. [intelReport][factionDescriptor]\n\n[factionWarning]\n\n[rewardHint]</li>

        <li>siteType->wilderness homestead</li>
        <li>siteType->remote cabin</li>
        <li>siteType->frontier dwelling</li>
        <li>siteType->isolated farmstead</li>
        <li>siteType->rough settlement</li>

        <li>intelReport->Outcasts and vagrants brave the wilderness in independent homesteads beyond the reach of the polite societies. [enemyFaction_name] is trying to eke out a living here."</li>
        <li>intelReport->Families and small groups stake out wilderness homesteads for all kinds of reasons. [enemyFaction_name] work a small plot of ground here.</li>
        <li>intelReport->Crashlanded pilots, expelled outlanders, and other transients coexist in wilderness homesteads. [enemyFaction_name] is working a claim here.</li>
        <li>intelReport->Independent homesteaders from [enemyFaction_name] are trying to scratch a living out of the ground here. They turn soil by hand and are building shelters before their first, and maybe last, winter.</li>
        <li>intelReport->Exiles, stranded families and convicted criminals must band together to survive the in wilderness. [enemyFaction_name] have established themsleves here using timber and scrap.</li>
		<li>intelReport->Life outside of settlements is sustained by cooperation between strangers. [enemyFaction_name] have made their place here.</li>
		<li>intelReport->Drifters, deserters and mixed groups of anyone else cut loose from organised society gather in remote homesteads. [enemyFaction_name] are trying to work the land here.</li>
	
        <li>rewardHint->They are substinence farmers, producing no goods except food for their families.</li>
        <li>rewardHint->All production and trade here goes directly toward keeping the group alive.</li>
        <li>rewardHint->They produce just enough to survive, trading small amounts for basic personal items and medicine.</li>
        <li>rewardHint->They store basic provisions like food, clothes medicine here.</li>
      </rulesStrings>
    </questDescriptionRules>

    <root Class="QuestNode_Sequence">
      <nodes>
        <li Class="QuestNode_SubScript">
          <def>Util_GetDefaultRewardValueFromPoints</def>
        </li>
        <li Class="QuestNode_SubScript">
          <def>Util_AdjustPointsForDistantFight</def>
        </li>
        <li Class="MiningOutpost.QuestNode_GetMapFallback" />

        <li Class="MiningOutpost.QuestNode_GetMiningFaction">
          <storeAs>enemyFaction</storeAs>
          <storeTemporaryAs>faction_temporary</storeTemporaryAs>
          <storeCorporateDescAs>factionDescriptor</storeCorporateDescAs>
          <storeColoredNameAs>coloredFactionName</storeColoredNameAs>
          <siteType>Homestead</siteType>
        </li>

        <li Class="MiningOutpost.QuestNode_UniversalSafeTileFinder">
          <storeAs>siteTile</storeAs>
          <minDistance>3</minDistance>
          <maxDistance>12</maxDistance>
        </li>

        <li Class="QuestNode_AddToList">
          <name>sitePartDefs</name>
          <value>HomesteadOutpost</value>
        </li>

        <li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>

        <li Class="QuestNode_GenerateSite">
          <sitePartsParams>$sitePartsParams</sitePartsParams>
          <tile>$siteTile</tile>
          <faction>$enemyFaction</faction>
          <storeAs>site</storeAs>
        </li>

        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>

        <li Class="QuestNode_WorldObjectTimeout">
          <worldObject>$site</worldObject>
          <isQuestTimeout>true</isQuestTimeout>
          <delayTicks>$(randInt(15,30)*60000)</delayTicks>
          <inSignalDisable>site.MapGenerated</inSignalDisable>
          <destroyOnCleanup>true</destroyOnCleanup>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest expired: [resolvedQuestName]</label>
                <text>The homestead operated by [enemyFaction_name] has been abandoned. The quest [resolvedQuestName] has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>site.Destroyed</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Letter">
                <label>Quest failed: [resolvedQuestName]</label>
                <text>The settlers from [enemyFaction_name] have fled with their belongings. The quest [resolvedQuestName] has ended.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
              </li>
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_Signal">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Notify_PlayerRaidedSomeone">
                <getRaidersFromMapParent>$site</getRaidersFromMapParent>
              </li>
              <li Class="QuestNode_CampLootReward" />
            </nodes>
          </node>
        </li>

        <li Class="QuestNode_End">
          <inSignal>site.AllEnemiesDefeated</inSignal>
          <outcome>Success</outcome>
        </li>

        <li Class="QuestNode_NoWorldObject">
          <worldObject>$site</worldObject>
          <node Class="QuestNode_End">
            <outcome>Fail</outcome>
          </node>
        </li>
      </nodes>
    </root>
  </QuestScriptDef>

</Defs>
