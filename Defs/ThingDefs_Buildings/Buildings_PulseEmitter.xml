<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>PulseEmitter</defName>
    <label>pulse emitter</label>
    <description>Pirates use these in even the most remote and extreme environments to seek out lucrative raid targets.</description>
    <thingClass>MiningOutpost.PulseEmitter.Building_PulseEmitter</thingClass>
    <tickerType>Normal</tickerType>
    <graphicData>
      <texPath>Things/Building/PulseEmitter</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.52, 2.52)</drawSize> 
      <drawOffset>(0, 0, 0.1)</drawOffset>
      <shadowData>
        <volume>(1.8, 0.8, 0.8)</volume>
      </shadowData>
    </graphicData>
    <drawerType>MapMeshAndRealTime</drawerType>
    <castEdgeShadows>true</castEdgeShadows>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <blockWind>true</blockWind>
    <fillPercent>0.5</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <WorkToBuild>4000</WorkToBuild>
      <Flammability>0.5</Flammability>
      <Mass>35</Mass>
    </statBases>
    <thingCategories>
      <li>BuildingsSpecial</li>
    </thingCategories>
    <size>(2,1)</size>
    <rotatable>false</rotatable>
    <minifiedDef>MinifiedThing</minifiedDef>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>150</costStuffCount>
    <costList>
      <ComponentIndustrial>6</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <hasInteractionCell>true</hasInteractionCell>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <designationCategory>Misc</designationCategory>
    <researchPrerequisites>
      <li>MicroelectronicsBasics</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <shortCircuitInRain>false</shortCircuitInRain>
        <basePowerConsumption>700</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable" />
      <li Class="CompProperties_Breakdownable" />
      <li Class="MiningOutpost.PulseEmitter.CompProperties_PulseEmitter" />
    </comps>
    <building>
      <destroySound>BuildingDestroyed_Metal_Medium</destroySound>
    </building>
  </ThingDef>

</Defs>
